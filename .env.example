POSTGRES_PASSWORD=your-strong-password-here

# Google OAuth (GCP Console에서 발급)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost/api/auth/google/callback

# JWT
JWT_SECRET=your-jwt-secret-here

# DB (k8s 로컬 포워딩 또는 직접 연결 시)
DATABASE_URL=postgresql+asyncpg://todayme:your-strong-password-here@localhost:5432/todayme

# Redis
REDIS_URL=redis://localhost:6379

# Frontend
FRONTEND_URL=http://localhost:5173

# Agent layer
OPENAI_API_KEY=your-openai-api-key
YOUTUBE_API_KEY=your-youtube-api-key          # GCP Console → YouTube Data API v3
GOOGLE_MAPS_API_KEY=your-google-maps-api-key  # GCP Console → Maps/Places API (New)
LANGSMITH_API_KEY=your-langsmith-api-key      # smith.langchain.com (선택)
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=today-me
